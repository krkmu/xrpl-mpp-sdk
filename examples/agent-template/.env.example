# XRPL MPP Agent Template -- example env.
# Copy to .env and fill in. ALL VARIABLES ARE OPTIONAL ON TESTNET.
#
# WARNING: never commit .env. Never put real seeds in .env in production.
#          See README.md "Wallet management" for how to do this properly.

# ---- Wallets (testnet only) ------------------------------------------------
# If unset, run-demo.ts auto-funds ephemeral testnet wallets via the faucet.
# RECIPIENT_SEED=sEdT...
# PAYER_SEED=sEdT...

# ---- Network ---------------------------------------------------------------
# One of: testnet (default), devnet, mainnet
# XRPL_NETWORK=testnet

# ---- Server ----------------------------------------------------------------
# PORT=3000
# SERVER_URL=http://localhost:3000

# ---- Pricing ---------------------------------------------------------------
# Drops charged per 1000 tokens of `maxTokens` in the intent.
# Default is 100000 drops = 0.1 XRP per 1k tokens.
# AGENT_PRICE_DROPS_PER_1K_TOKENS=100000

# ---- MPP -------------------------------------------------------------------
# Server-side secret used by mppx to sign challenges. Rotate per environment.
# MPP_SECRET_KEY=change-me-in-production
