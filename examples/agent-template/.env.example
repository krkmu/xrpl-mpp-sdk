# XRPL MPP Agent Template -- example env.
# Copy to .env and fill in. Only ANTHROPIC_API_KEY is REQUIRED; everything
# else has sensible testnet defaults.
#
# WARNING: never commit .env. Never put real seeds in .env in production.
#          See README.md "Wallet management" for how to do this properly.

# ---- Anthropic (REQUIRED) --------------------------------------------------
# Get a free key (with $5 trial credit) at https://console.anthropic.com.
# The same key is used by BOTH the agent (client) and the service (server)
# in this demo. In a real deployment they would be two separate keys belonging
# to two separate organisations.
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional. Defaults to claude-haiku-4-5 (cheapest / fastest).
# Other options: claude-sonnet-4-6, claude-opus-4-7
# ANTHROPIC_MODEL=claude-haiku-4-5

# ---- Wallets (testnet only) ------------------------------------------------
# If unset, run-demo.ts auto-funds ephemeral testnet wallets via the faucet.
# RECIPIENT_SEED=sEdT...
# PAYER_SEED=sEdT...

# ---- Network ---------------------------------------------------------------
# One of: testnet (default), devnet, mainnet
# XRPL_NETWORK=testnet

# ---- Server ----------------------------------------------------------------
# PORT=3000
# SERVER_URL=http://localhost:3000

# ---- Pricing ---------------------------------------------------------------
# Drops charged per 1000 output tokens of the brief's `maxTokens`.
# Default is 1_000_000 drops = 1 XRP per 1k tokens. Override at will.
# AGENT_PRICE_DROPS_PER_1K_TOKENS=1000000

# ---- MPP -------------------------------------------------------------------
# Server-side secret used by mppx to sign challenges. Rotate per environment.
# MPP_SECRET_KEY=change-me-in-production
