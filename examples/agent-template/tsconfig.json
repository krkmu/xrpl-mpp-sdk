{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,

    // Path mapping below is ONLY needed when running this template from
    // inside the xrpl-mpp-sdk monorepo, where the SDK source is sibling to
    // this folder. If you copy this folder out of the repo to use it as a
    // starter, DELETE the `baseUrl` and `paths` keys and add `xrpl-mpp-sdk`
    // as a normal dependency in package.json.
    "baseUrl": ".",
    "paths": {
      "xrpl-mpp-sdk": ["../../sdk/src/index.ts"],
      "xrpl-mpp-sdk/server": ["../../sdk/src/server/index.ts"],
      "xrpl-mpp-sdk/client": ["../../sdk/src/client/index.ts"],
      "xrpl-mpp-sdk/channel": ["../../sdk/src/channel/index.ts"],
      "xrpl-mpp-sdk/channel/server": ["../../sdk/src/channel/server/index.ts"],
      "xrpl-mpp-sdk/channel/client": ["../../sdk/src/channel/client/index.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}
